{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "plugin-gentleman",
  "version": "1.2.0",
  "description": "OpenCode TUI plugin featuring Mustachi - an animated ASCII mascot with eyes, mustache, and optional motivational phrases during busy states",
  "type": "module",
  "exports": {
    "./tui": {
      "import": "./tui.tsx",
      "config": {
        "enabled": true,
        "theme": "gentleman",
        "set_theme": false,
        "show_detected": true,
        "show_os": true,
        "show_providers": true,
        "show_metrics": true,
        "animations": true,
        "cost_budget_usd": 1
      }
    }
  },
  "files": [
    "tui.tsx",
    "runtime/",
    "ui/",
    "utils/",
    "config.ts",
    "detection.ts",
    "ascii-frames.ts",
    "phrases.ts",
    "types.ts",
    "message-utils.ts",
    "mcp-utils.ts",
    "animation-utils.ts",
    "progress-components.tsx",
    "gentleman.json"
  ],
  "engines": {
    "opencode": ">=1.3.13"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  },
  "keywords": [
    "opencode",
    "plugin",
    "theme",
    "gentleman",
    "tui",
    "ascii",
    "mustachi"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IrrealV/plugin-gentleman.git"
  },
  "homepage": "https://github.com/IrrealV/plugin-gentleman#readme",
  "bugs": {
    "url": "https://github.com/IrrealV/plugin-gentleman/issues"
  }
}
